{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": false,
    "resolveJsonModule": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noEmit": true,
    "jsx": "preserve",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@jobautomation/config": ["packages/config/src/index.ts"],
      "@jobautomation/core": ["packages/core/src/index.ts"],
      "@jobautomation/db": ["packages/db/src/index.ts"],
      "@jobautomation/discovery": ["packages/discovery/src/index.ts"]
    }
  }
}
